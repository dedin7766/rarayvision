# =========================
# Database Configuration
# =========================
# Database (Default uses local SQLite file, no MySQL needed!)
# For MySQL: DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/rarayvision
DATABASE_URL=sqlite:///./rarayvision.db

# =========================
# JWT Authentication
# =========================
# Generate a secure random key with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=paste-your-generated-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080


# =========================
# Frontend (inside frontend/.env)
# =========================
# VITE_API_BASE_URL=http://127.0.0.1:5000
