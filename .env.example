# =========================
# Environment
# =========================
# Set to "production" to enforce SECRET_KEY and strict CORS.
# Defaults to "development" (allows missing SECRET_KEY and open CORS for easy local setup).


# =========================
# Database Configuration
# =========================
# Database (Default uses local SQLite file, no MySQL needed!)

# DB_USER=
# DB_PASS=
# DB_HOST=localhost
# DB_NAME=

DATABASE_URL=sqlite:///./rarayvision.db

# =========================
# JWT Authentication
# =========================
# REQUIRED — app will refuse to start if this is empty.
# Generate a secure random key with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080


# =========================
# CORS
# =========================
# REQUIRED for production — comma-separated list of allowed frontend origins.
# Example: ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
# For local dev you can use: ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=


# =========================
# Frontend (inside frontend/.env)
# =========================
# VITE_API_BASE_URL=http://127.0.0.1:5000
